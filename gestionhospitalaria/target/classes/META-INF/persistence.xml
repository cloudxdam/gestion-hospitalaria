<?xml version="1.0" encoding="UTF-8"?>
<!-- Persistence deployment descriptor for dev profile -->
<persistence xmlns="http://java.sun.com/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="http://java.sun.com/xml/ns/persistence http://java.sun.com/xml/ns/persistence/persistence_1_0.xsd"
             version="1.0">

    <persistence-unit name="gestionhospitalariaPU" transaction-type="RESOURCE_LOCAL">
            <!-- Provider JPA (Hibernate) -->
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <!-- Clases de entidad (opcional si se usa auto-detección) -->
        <class>com.pachedev.modelo.Administrativo</class>
        <class>com.pachedev.modelo.Cita</class>
        <class>com.pachedev.modelo.Departamento</class>
        <class>com.pachedev.modelo.Enfermero</class>
        <class>com.pachedev.modelo.Habitacion</class>
        <class>com.pachedev.modelo.Historial</class>
        <class>com.pachedev.modelo.Ingreso</class>
        <class>com.pachedev.modelo.Medicamento</class>
        <class>com.pachedev.modelo.Medico</class>
        <class>com.pachedev.modelo.Paciente</class>
        <class>com.pachedev.modelo.Personalmedico</class>
        <class>com.pachedev.modelo.Tratamiento</class>
        <class>com.pachedev.modelo.TratamientoMedicamento</class>
        <!-- Excluir clases no listadas (false para auto-detección) -->
        <exclude-unlisted-classes>false</exclude-unlisted-classes>        
        
        <properties>
            <!-- ========================================== -->
            <!-- CONFIGURACIÓN DE CONEXIÓN A BASE DE DATOS -->
            <!-- ========================================== -->
            <!-- URL de conexión -->
            <!--
            <property name="jakarta.persistence.schema-generation.scripts.action" value="create"/>
            <property name="jakarta.persistence.schema-generation.scripts.create-target" value="create_db.sql"/>
            -->
            <property name="jakarta.persistence.schema-generation.database.action" value="update"/>
            <property name="jakarta.persistence.schema-generation.scripts.action" value="create"/>
            <property name="jakarta.persistence.schema-generation.scripts.create-target" value="create_db.sql"/>
            <property name="jakarta.persistence.jdbc.url"
            value="jdbc:mysql://127.0.0.1:3306/hospital_db?serverTimezone=Europe/Madrid"/>
            <!-- Usuario y contraseña -->
            <property name="jakarta.persistence.jdbc.user" value="root"/>
            <property name="jakarta.persistence.jdbc.password" value="password"/>
            <!-- Driver JDBC -->
            <property name="jakarta.persistence.jdbc.driver"
            value="com.mysql.cj.jdbc.Driver"/>
            <!-- ========================================== -->
            <!-- CONFIGURACIÓN DE HIBERNATE -->
            <!-- ========================================== -->
            <!-- Dialecto SQL específico de la base de datos -->
            <property name="hibernate.dialect"
            value="org.hibernate.dialect.MySQLDialect"/>
            <!-- Gestión automática del esquema de BD -->
            <!-- Valores: none, validate, update, create, create-drop -->
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <!-- Mostrar SQL generado por Hibernate -->
            <property name="hibernate.show_sql" value="true"/>
            <!-- Formatear SQL para mejor legibilidad -->
            <property name="hibernate.format_sql" value="true"/>
            <!-- Resaltar SQL en consola con colores -->
            <property name="hibernate.highlight_sql" value="true"/>
            <!-- Mostrar comentarios en SQL -->
            <property name="hibernate.use_sql_comments" value="true"/>
            <!-- ========================================== -->
            <!-- POOL DE CONEXIONES (HikariCP) -->
            <!-- ========================================== -->
            <!-- Proveedor de pool de conexiones -->
            <!---->
            <property name="hibernate.connection.provider_class"
            value="org.hibernate.hikaricp.internal.HikariCPConnectionProvider"/>
            <!-- Configuración de HikariCP -->
            <property name="hibernate.hikari.connectionTimeout" value="20000"/>
            <property name="hibernate.hikari.minimumIdle" value="5"/>
            <property name="hibernate.hikari.maximumPoolSize" value="20"/>
            <property name="hibernate.hikari.idleTimeout" value="300000"/>
            <property name="hibernate.hikari.maxLifetime" value="1200000"/>
            <!-- ========================================== -->
            <!-- OPTIMIZACIONES DE RENDIMIENTO -->
            <!-- ========================================== -->
            <!-- Tamaño de lote para inserciones/actualizaciones -->
            <property name="hibernate.jdbc.batch_size" value="20"/>
            <!-- Ordenar inserciones y actualizaciones -->
            <property name="hibernate.order_inserts" value="true"/>
            <property name="hibernate.order_updates" value="true"/>
            <!-- Habilitar estadísticas (útil en desarrollo) -->
            <property name="hibernate.generate_statistics" value="false"/>
            <!-- ========================================== -->
            <!-- CACHÉ DE SEGUNDO NIVEL (Opcional) -->
            <!-- ========================================== -->
            <!-- Habilitar caché de segundo nivel -->
            <property name="hibernate.cache.use_second_level_cache" value="false"/>
            <!-- Habilitar caché de consultas -->
            <property name="hibernate.cache.use_query_cache" value="false"/>
        </properties>
    </persistence-unit>
</persistence>
